<Window x:Class="InjectorUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Injector UI"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="600"
        Background="{StaticResource BgDark}"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgMedium}" CornerRadius="6" Padding="10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnInject"
                        Grid.Column="0"
                        Content="Inject"
                        Width="80" Height="32"
                        Background="{StaticResource BgLight}"
                        Foreground="{StaticResource FgAccent}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="BtnInject_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="BtnExecute"
                        Grid.Column="1"
                        Content="Execute"
                        Width="80" Height="32"
                        Margin="8,0,0,0"
                        Background="{StaticResource BgLight}"
                        Foreground="{StaticResource FgGreen}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="BtnExecute_Click"
                        IsEnabled="False">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="BtnClear"
                        Grid.Column="2"
                        Content="Clear"
                        Width="60" Height="32"
                        Margin="8,0,0,0"
                        Background="{StaticResource BgLight}"
                        Foreground="{StaticResource FgPrimary}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="BtnClear_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="Gray" Margin="0,0,6,0"/>
                    <TextBlock x:Name="TxtStatus"
                               Text="Idle"
                               Foreground="{StaticResource FgPrimary}"
                               VerticalAlignment="Center"
                               FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <CheckBox x:Name="ChkBytecode"
                              Foreground="{StaticResource FgPrimary}"
                              Content="Bytecode"
                              FontSize="12"
                              VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtScriptType"
                               Text="Source"
                               Foreground="{StaticResource FgAccent}"
                               FontSize="12"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource BgMedium}" CornerRadius="6">
            <wv2:WebView2 x:Name="WebView" Margin="2"/>
        </Border>

        <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" Background="{StaticResource BorderColor}"/>

        <Border Grid.Row="3" Background="{StaticResource BgMedium}" CornerRadius="6">
            <TextBox x:Name="TxtOutput"
                     Background="Transparent"
                     Foreground="{StaticResource FgPrimary}"
                     BorderThickness="0"
                     FontFamily="Consolas"
                     FontSize="13"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     Margin="8"
                     AcceptsReturn="True"/>
        </Border>

        <Border Grid.Row="4" Background="{StaticResource BgMedium}" CornerRadius="4" Padding="6,4" Margin="0,4,0,0">
            <TextBlock x:Name="TxtLog"
                       Foreground="{StaticResource FgPrimary}"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>
