<Application x:Class="InjectorUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <SolidColorBrush x:Key="BgDark" Color="#FF1E1E1E"/>
                    <SolidColorBrush x:Key="BgMedium" Color="#FF2D2D2D"/>
                    <SolidColorBrush x:Key="BgLight" Color="#FF3C3C3C"/>
                    <SolidColorBrush x:Key="FgPrimary" Color="#FFD4D4D4"/>
                    <SolidColorBrush x:Key="FgAccent" Color="#FF569CD6"/>
                    <SolidColorBrush x:Key="FgGreen" Color="#FF4EC9B0"/>
                    <SolidColorBrush x:Key="FgRed" Color="#FFF44747"/>
                    <SolidColorBrush x:Key="BorderColor" Color="#FF404040"/>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
